# ============================================================
# Hytale Server Management Panel — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# The install.sh script generates secrets automatically.
# ============================================================

# ─── Database ───────────────────────────────────────────────
DB_PASSWORD=

# ─── Docker / Host Integration ──────────────────────────────
# Shared numeric GID for the helper socket directory + API container.
PANEL_SOCKET_GID=2001
# Override these if 3000/4000/5432 are already in use on the VPS host.
WEB_HOST_PORT=3000
API_HOST_PORT=4000
POSTGRES_HOST_PORT=5432

# ─── API Server ─────────────────────────────────────────────
NODE_ENV=production
# Sessions are DB-backed opaque tokens; SESSION_SECRET is reserved for future
# cookie signing and is not currently consumed at runtime. Still required at
# startup so enabling signing later won't be a breaking env change.
SESSION_SECRET=
SESSION_MAX_AGE_HOURS=4
SESSION_IDLE_TIMEOUT_MINUTES=60
ADMIN_SESSION_IDLE_TIMEOUT_MINUTES=15
COOKIE_DOMAIN=
CSRF_SECRET=

# ─── Helper Service Communication ──────────────────────────
HELPER_HMAC_SECRET=
# Container-visible helper socket path. The host helper itself listens on
# /opt/hytale-panel/run/hytale-helper.sock and Docker bind-mounts that into the
# API container at /run/hytale-helper/hytale-helper.sock.
HELPER_SOCKET_PATH=/run/hytale-helper/hytale-helper.sock

# ─── Reverse Proxy ──────────────────────────────────────────
# For first private testing via SSH tunnel, these can be:
# CORS_ORIGIN=http://localhost:43000
# WS_ALLOWED_ORIGINS=http://localhost:43000
# In production, WS_ALLOWED_ORIGINS must be set or the console WebSocket is
# rejected by design.
TRUST_PROXY=127.0.0.1
CORS_ORIGIN=https://panel.yourdomain.com
WS_ALLOWED_ORIGINS=https://panel.yourdomain.com

# ─── Rate Limiting ──────────────────────────────────────────
MAX_FAILED_LOGINS=10
LOCKOUT_DURATION_MINUTES=30
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_MS=900000
GLOBAL_RATE_LIMIT_MAX=100
GLOBAL_RATE_LIMIT_WINDOW_MS=60000

# ─── Retention ──────────────────────────────────────────────
AUDIT_LOG_RETENTION_DAYS=90
CRASH_LOG_RETENTION_DAYS=30

# ─── Helper Service (.env for /opt/hytale-panel/helper/) ────
# These are used by the helper service running on the host.
# HELPER_SOCKET_PATH=/opt/hytale-panel/run/hytale-helper.sock
# HELPER_HMAC_SECRET=
# HYTALE_ROOT=/opt/hytale
# BACKUP_PATH=/opt/hytale-backups
# HYTALE_SERVICE_NAME=hytale-tmux.service
# TMUX_SESSION=hytale
# WHITELIST_PATH=/opt/hytale/Server/whitelist.json
# BANS_PATH=/opt/hytale/Server/bans.json
# WORLDS_PATH=/opt/hytale/Server/worlds

# ─── Web Frontend ──────────────────────────────────────────
# NEXT_PUBLIC_API_URL=http://api:4000
