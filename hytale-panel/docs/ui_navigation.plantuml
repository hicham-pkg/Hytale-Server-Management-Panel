@startuml Hytale Panel UI Navigation

skinparam backgroundColor #1a1a2e
skinparam defaultFontColor #e0e0e0
skinparam stateBorderColor #4a4a6a
skinparam stateBackgroundColor #2a2a4a

title Hytale Panel - UI Navigation Flow

state "Login" as Login {
    [*] --> LoginForm
    LoginForm --> TotpVerify : 2FA required
    TotpVerify --> LoginForm : back
}

state "Dashboard" as Dashboard {
    state "Server Status Card" as StatusCard
    state "System Stats Card" as StatsCard
    state "Server Controls" as Controls
    state "Recent Warnings" as Warnings
}

state "Live Console" as Console {
    state "Log Output Stream" as LogStream
    state "Command Input" as CmdInput
    state "Command History" as CmdHistory
}

state "Whitelist" as Whitelist {
    state "Player List" as WLList
    state "Add Player" as WLAdd
    state "Remove Confirm" as WLRemove
}

state "Bans" as Bans {
    state "Ban List" as BanList
    state "Add Ban" as BanAdd
    state "Remove Confirm" as BanRemove
}

state "Backups" as Backups {
    state "Backup List" as BkList
    state "Create Backup" as BkCreate
    state "Restore Confirm" as BkRestore
    state "Delete Confirm" as BkDelete
}

state "Crash History" as Crashes {
    state "Event Timeline" as CrashTimeline
    state "Event Detail" as CrashDetail
}

state "Audit Log" as AuditLog
state "Settings" as Settings {
    state "Paths & Config" as SettingsPaths
    state "Security" as SettingsSecurity
    state "Users" as SettingsUsers
    state "2FA Setup" as Settings2FA
}

' Main navigation
Login --> Dashboard : successful login
Dashboard --> Console : sidebar nav
Dashboard --> Whitelist : sidebar nav
Dashboard --> Bans : sidebar nav
Dashboard --> Backups : sidebar nav
Dashboard --> Crashes : sidebar nav
Dashboard --> AuditLog : sidebar nav
Dashboard --> Settings : sidebar nav

' Cross navigation (all pages accessible via sidebar)
Console --> Dashboard : sidebar nav
Whitelist --> Dashboard : sidebar nav
Bans --> Dashboard : sidebar nav
Backups --> Dashboard : sidebar nav
Crashes --> Dashboard : sidebar nav
AuditLog --> Dashboard : sidebar nav
Settings --> Dashboard : sidebar nav

' Internal navigation
CrashTimeline --> CrashDetail : click event
CrashDetail --> CrashTimeline : back

' Logout from any page
Dashboard --> Login : logout
Console --> Login : session expired

@enduml