@startuml Hytale Panel Architecture

!define RECTANGLE class

skinparam backgroundColor #1a1a2e
skinparam defaultFontColor #e0e0e0
skinparam packageBorderColor #4a4a6a
skinparam componentBorderColor #4a4a6a
skinparam noteBorderColor #4a4a6a
skinparam arrowColor #7c7cff

title Hytale Server Management Panel - Component Architecture

package "Browser (Trust Zone 0 - Untrusted)" #2a2a4a {
    [Next.js Frontend\n(SSR + CSR)] as frontend
    [WebSocket Client] as wsclient
    note right of frontend
        - React 18 + Tailwind + shadcn/ui
        - Session cookie auth
        - CSRF token in headers
        - No direct host access
    end note
}

package "Docker Network (Trust Zone 1 - Low Trust)" #2a3a4a {
    [Next.js SSR Container\nPort 3000] as nextssr
    [Fastify API Server\nPort 4000] as api
    database "PostgreSQL 16\nPort 5432 (internal)" as db

    note right of api
        - REST + WebSocket endpoints
        - Zod validation on all inputs
        - Session management
        - Audit logging
        - Rate limiting
        - CSRF protection
        - Runs as non-root
    end note
}

package "Host OS (Trust Zone 2 - Medium Trust)" #3a2a4a {
    [hytale-helper.service\n(Privileged Helper)] as helper
    note right of helper
        - Listens on Unix socket ONLY
        - HMAC-SHA256 signed requests
        - Allowlisted operations only
        - Runs as hytale-helper user
        - Minimal sudoers for systemctl
    end note
}

package "Game Server (Trust Zone 3 - Isolated)" #3a4a2a {
    [hytale-tmux.service\n(Hytale Server in tmux)] as gameserver
    folder "/opt/hytale" as gamedir {
        file "Server/whitelist.json" as whitelist
        file "Server/bans.json" as bans
        file "Server/worlds/" as worlds
    }
    folder "/opt/hytale-backups" as backupdir
}

' Connections
frontend -down-> nextssr : "HTTPS\n(via reverse proxy)"
wsclient -down-> api : "WSS\n(via reverse proxy)"
nextssr -right-> api : "HTTP\n(Docker internal)"
api -down-> db : "TCP 5432\n(parameterized queries)"
api -down-> helper : "Unix Socket\n/run/hytale-helper/hytale-helper.sock\n(HMAC signed)"
helper -down-> gameserver : "systemctl\n(sudo, exact commands)"
helper -down-> gameserver : "tmux send-keys\n(sanitized input)"
helper -down-> gamedir : "File I/O\n(path-guarded)"
helper -down-> backupdir : "tar/restore\n(path-guarded)"

' External
cloud "Reverse Proxy\n(nginx/Caddy/CF Tunnel)" as proxy
proxy -down-> nextssr : "Port 3000"
proxy -down-> api : "Port 4000"

@enduml
